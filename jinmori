#!/bin/sh

CMD_NAME="jinmori"
CMD_VERSION="0.1.0"

usage() {
	cat <<EOF
A Standard ML package manager focusing on MLton

Usage: $CMD_NAME [OPTIONS] [COMMAND]

Options:
	--help			Print help (this page)
	--version 		Print version info

Commands:
	setup	Initialize $CMD_NAME with the current user
	new	Create a new sml project

See '$CMD_NAME help <command>' for more information on a specific command.
EOF
}

update_path() {
	shell_config="$HOME/.bashrc"
	if [ -n "$ZSH_VERSION" ]; then
		shell_config="$HOME/.zshrc"
	fi
	start_mark="# <<< Autogenerated by jinmori"
	end_mark="# >>> Autogenerated by jinmori"

	if grep -xqF "$start_mark" "$shell_config"; then
		return
	fi

	cat >>"$shell_config" <<EOF

$start_mark

case ":\$PATH:" in
*:$HOME/.jinmori/bin:*)
	;;
*)
	export PATH=$HOME/.jinmori/bin\${PATH:+:\${PATH}}
	;;
esac

$end_mark
EOF
}

CMD_PATH="$0"

case "$1" in
setup)
	shift
	DIR="$HOME/.jinmori"
	FORCE=0
	PATHAPPEND=1

	if ! OPTIONS=$(getopt --options d:f --longoptions dest:,force,no-modify-path -- "$@"); then
		exit 1
	fi
	eval set -- "$OPTIONS"

	while true; do
		case "$1" in
		-d | --dest)
			DIR="$2"
			shift 2
			;;
		-f | --force)
			FORCE=1
			shift
			;;
		--no-modify-path)
			PATHAPPEND=0
			shift
			;;
		--)
			shift
			break
			;;
		*)
			echo "Unknown option '$1'" >&2
			usage
			exit 1
			;;
		esac
	done

	tmp_path=""
	if [ -d "$DIR" ]; then
		if [ "$FORCE" -eq 1 ]; then
			rm -rf "$DIR"
		else
			echo "Directory $DIR already exists. You may have set up $CMD_NAME already."
			printf "Do you want to remove the existing installation and overwrite? (y/N) "

			read -r response
			case "$response" in
			[yY][eE][sS] | [yY])
				tmp_path=$(mktemp)
				cp -p -- "$CMD_PATH" "$tmp_path"
				CMD_PATH="$tmp_path"
				rm -rf "$DIR"
				;;
			*)
				echo "Aborting. $DIR was not modified." >&2
				exit 1
				;;
			esac
		fi
	fi

	mkdir -p "$DIR/bin" "$DIR/deps"
	echo "Initialized jinmori directory at $DIR" >&2
	cp -- "$CMD_PATH" "$DIR/bin/$CMD_NAME"
	if [ -n "$tmp_path" ]; then
		rm --force "$tmp_path"
	fi

	if [ "$PATHAPPEND" -eq 1 ]; then
		update_path
	fi
	;;

new)
	shift
	case "$1" in
	"")
		echo "No project name provided." >&2
		exit 1
		;;
	*[!A-Za-z]*)
		echo "Project name must only contain ASCII alphabets." >&2
		exit 1
		;;
	*)
		PROJ="$1"
		shift

		src="$PROJ/src"
		tests="$PROJ/tests"
		bin="$PROJ/bin"
		main=$(echo "$PROJ" | awk '{ $1 = toupper(substr($1, 1, 1)) substr($1, 2); print }')

		if ! mkdir -p "$src" "$tests" "$bin" 2>/dev/null; then
			echo "Destination \`$PROJ\` already exists." >&2
			exit 1
		fi

		cat >"$src/$main.sml" <<EOF
structure $main:
sig
  val greeting: string
end =
struct
  val hello = "Hello,"
  val world = "World!"
  val greeting = hello ^ world ^ "\n"
end
EOF

		cat >"$src/Exec.sml" <<EOF
val () = print $main.greeting
EOF

		cat >"$tests/$main.sml" <<EOF
if true = false then
	raise Fail "The fabric of reality crumbles..."
else
	()
EOF

		cat >"$src/src.mlb" <<EOF
\$(SML_LIB)/basis/basis.mlb
$main.sml
EOF

		cat >"$PROJ/$PROJ.mlb" <<EOF
src/src.mlb
src/Exec.sml
EOF

		cat >"$PROJ/$PROJ.tests.mlb" <<EOF
src/src.mlb
tests/$main.sml
EOF

		cat >"$PROJ/Makefile" <<EOF
BIN := \$(CURDIR)/bin
SRC := \$(CURDIR)/src
TESTS := \$(CURDIR)/tests

APP := \$(BIN)/$PROJ
TESTER := \$(BIN)/testall

MLTON_FLAGS := $MLTON_FLAGS

all: \$(APP) \$(TESTER)
.PHONY: test

\$(APP): \$(SRC)/*.sml
	mlton \$(MLTON_FLAGS) -output \$@ $PROJ.mlb

\$(TESTER): \$(SRC)/*.sml \$(TESTS)/*.sml
	mlton \$(MLTON_FLAGS) -output \$@ $PROJ.tests.mlb

test: \$(TESTER)
	\$(TESTER)

clean:
	rm -f \$(BIN)/*
EOF
		;;
	esac
	;;

help | --help | -h)
	shift
	case "$1" in
	setup)
		cat <<EOF
Initialize $CMD_NAME with the current user

Usage: $CMD_NAME setup [OPTIONS]

Options:
	-d, --dest <dir>	Specify the directory to use as \$JINMORI_HOME (default: \$HOME/.jinmori)
	-f, --force		Overwrite existing \$JINMORI_HOME
	--no-modify-path	Prevent modifying the shell PATH variable
EOF
		;;
	new)
		cat <<EOF
Create a new sml project

Usage: $CMD_NAME new PROJECT

Caveats:
	PROJECT must only contain ASCII alphabets.
	This is because the project name is used to define some boilerplate code,
	and sml only (officially) supports ASCII.
EOF
		;;
	"")
		usage
		;;
	*)
		echo "Error: Unknown command '$1'" >&2
		exit 1
		;;
	esac
	;;
--version)
	shift
	echo "$CMD_VERSION"
	;;
"")
	usage
	;;
*)
	echo "Error: Unknown command or flag '$1'" >&2
	usage
	exit 1
	;;
esac
