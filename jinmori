#!/bin/sh

CMD_NAME="jinmori"
CMD_VERSION="0.1.0"
JINMORI_HOME="${JINMORI_HOME:-$HOME/.jinmori}"
VERBOSE=0

usage() {
	cat <<EOF
A Standard ML package manager focusing on MLton

Usage: $CMD_NAME [OPTIONS] [COMMAND]

Options:
	--help		Print help (this page)
	--version	Print version info

Commands:
	setup	Eagerly setup $CMD_NAME and add to path
	new	Create a new sml project
	add	Add dependencies to a project

See '$CMD_NAME help <command>' for more information on a specific command.
EOF
}

usage__setup() {
	cat <<SETUP
Initialize $CMD_NAME with the current user

Usage: $CMD_NAME setup [OPTIONS]

Options:
	-d, --dest <dir>	Specify the directory to use as \$JINMORI_HOME (default: \$HOME/.jinmori)
	-f, --force		Overwrite existing \$JINMORI_HOME
	--no-modify-path	Prevent modifying the shell PATH variable
SETUP
}

usage__new() {
	cat <<NEW
Create a new sml project

Usage: $CMD_NAME new <PROJECT>

Caveats:
	PROJECT must only contain ASCII alphabets.
	This is partially because the project name is used to define some boilerplate code,
	and sml only (officially) supports ASCII.
NEW
}

usage__add() {
	cat <<ADD
Add dependencies to a project

Usage: $CMD_NAME add <DEP> ...
ADD
}

update_path() {
	shell_config="$HOME/.bashrc"
	if [ -n "$ZSH_VERSION" ]; then
		shell_config="$HOME/.zshrc"
	fi
	start_mark="# <<< Autogenerated by jinmori"
	end_mark="# >>> Autogenerated by jinmori"

	if grep -xqF "$start_mark" "$shell_config"; then
		return
	fi

	cat >>"$shell_config" <<EOF

$start_mark

case ":\$PATH:" in
*:$JINMORI_HOME/bin:*)
	;;
*)
	export PATH=$JINMORI_HOME/bin\${PATH:+:\${PATH}}
	;;
esac

$end_mark
EOF
}

init_proj() {
	proj=$1

	cat >"$proj/src/$main.sml" <<MAIN
structure $main:
sig
  val greeting: string
end =
struct
  val hello = "Hello,"
  val world = "World!"
  val greeting = hello ^ world ^ "\n"
end
MAIN

	cat >"$proj/src/Exec.sml" <<CLI
val () = print $main.greeting
CLI

	cat >"$proj/tests/$main.sml" <<"TEST"
if true = false then
	raise Fail "The fabric of reality crumbles..."
else
	()
TEST

	cat >"$proj/src/src.mlb" <<SRC
\$(SML_LIB)/basis/basis.mlb
$main.sml
SRC

	cat >"$proj/$proj.mlb" <<"MAIN_MLB"
src/src.mlb
src/Exec.sml
MAIN_MLB

	cat >"$proj/$proj.tests.mlb" <<EOF
src/src.mlb
tests/$main.sml
EOF

	cat >"$proj/Makefile" <<EOF
BIN := \$(CURDIR)/bin
SRC := \$(CURDIR)/src
TESTS := \$(CURDIR)/tests

APP := \$(BIN)/$proj
TESTER := \$(BIN)/testall

MLTON_FLAGS := $MLTON_FLAGS

all: \$(APP) \$(TESTER)
.PHONY: test

\$(APP): \$(SRC)/*.sml
	mlton \$(MLTON_FLAGS) -output \$@ $proj.mlb

\$(TESTER): \$(SRC)/*.sml \$(TESTS)/*.sml
	mlton \$(MLTON_FLAGS) -output \$@ $proj.tests.mlb

test: \$(TESTER)
	\$(TESTER)

clean:
	rm -f \$(BIN)/*
EOF
}

__cond_log() {
	level="$1"
	shift
	if [ "$VERBOSE" -ge "$level" ]; then
		echo "$@" 2>&1
	fi
}

info_log() {
	__cond_log 1 "INFO: " "$@"
}

dbg_log() {
	__cond_log 2 "DBG: " "$@"
}

symlink_deps() {
	deps="$JINMORI_HOME/deps"
	project_dir="$1"
	target="$2"

	if [ ! -d "$deps/$target" ]; then
		info_log "$target not present. Downloading from github"
		if git clone "https://$target.git" "$deps/$target" >/dev/null 2>&1; then
			tail -n +4 "$deps/$target/sml.pkg" |
				head -n -1 |
				awk '{$1=$1;print $1}' |
				while IFS= read -r transitive_dep; do
					dbg_log "Detected transitive dependency $transitive_dep of $target"
					if ! symlink_deps "$deps/$target" "$transitive_dep"; then
						exit "$?"
					fi
				done
		else
			echo "Error: could not find package $target" >&2
			return 1
		fi
	fi

	mkdir -p "$project_dir/lib/$(dirname "$target")"
	ln -s "$deps/$target" "$project_dir/lib/$target"

	return 0
}

CMD_PATH="$0"

main() {
	case "$1" in
	setup)
		shift
		FORCE=0
		PATHAPPEND=1

		if ! OPTIONS=$(getopt --options d:f --longoptions dest:,force,no-modify-path -- "$@"); then
			exit 1
		fi
		eval set -- "$OPTIONS"

		while true; do
			case "$1" in
			-d | --dest)
				JINMORI_HOME="$2"
				shift 2
				;;
			-f | --force)
				FORCE=1
				shift
				;;
			--no-modify-path)
				PATHAPPEND=0
				shift
				;;
			--)
				shift
				break
				;;
			*)
				echo "Unknown option '$1'" >&2
				usage
				exit 1
				;;
			esac
		done

		tmp_path=""
		if [ -d "$JINMORI_HOME" ]; then
			if [ "$FORCE" -eq 1 ]; then
				rm -rf "$DIR"
			else
				echo "Directory $JINMORI_HOME already exists. You may have set up $CMD_NAME already."
				printf "Do you want to remove the existing installation and reinstall? (y/N) "

				read -r response
				case "$response" in
				[yY][eE][sS] | [yY])
					tmp_path=$(mktemp)
					cp --preserve -- "$CMD_PATH" "$tmp_path"
					dbg_log "Copied jinmori command to $tmp_path"
					CMD_PATH="$tmp_path"
					rm -rf "$DIR"
					;;
				*)
					echo "Aborting. $JINMORI_HOME was not modified." >&2
					exit 1
					;;
				esac
			fi
		fi

		mkdir -p "$JINMORI_HOME/bin" "$JINMORI_HOME/deps"
		echo "Initialized jinmori home directory at $JINMORI_HOME" >&2
		cp -- "$CMD_PATH" "$JINMORI_HOME/bin/$CMD_NAME" # This script is technically not a binary, but it's more convenient this way
		if [ -n "$tmp_path" ]; then
			rm --force "$tmp_path"
		fi

		if [ "$PATHAPPEND" -eq 1 ]; then
			update_path
		fi
		;;

	new)
		shift
		case "$1" in
		"")
			echo "Error: No project name provided." >&2
			exit 1
			;;
		*[!A-Za-z]*)
			echo "Error: Project name must only contain ASCII alphabets." >&2
			exit 1
			;;
		*)
			proj="$1"
			main=$(echo "$proj" | awk '{ $1 = toupper(substr($1, 1, 1)) substr($1, 2); print }')

			if ! mkdir -p "$proj/src" "$proj/tests" "$proj/bin" 2>/dev/null; then
				echo "Error: Destination \`$proj\` already exists." >&2
				exit 1
			fi
			shift
			init_proj "$proj"
			;;
		esac
		;;

	add)
		shift
		if [ -z "$1" ]; then
			echo "Error: Dependencies not specified" >&2
			exit 1
		fi

		project_dir=$(pwd)
		while [ "$project_dir" != "/" ]; do
			if [ -f "$project_dir/sml.pkg" ]; then
				dbg_log "Project directory found at $project_dir"
				for target in "$@"; do
					info_log "Detected top level dependency: $target"
					symlink_deps "$project_dir" "$target"
					exit "$?"
				done
			else
				dir=$(dirname "$dir")
			fi
		done

		echo "Error: could not find sml.pkg at the current working directory or any of its parent directory" >&2
		exit 1
		;;
	--verbose)
		shift
		case "$1" in
		0)
			VERBOSE=0
			shift
			main "$@"
			;;
		"" | 1)
			VERBOSE=1
			shift
			main "$@"
			;;
		2)
			VERBOSE=2
			shift
			main "$@"
			;;
		*)
			echo "Error: invalid verbosity level $1"
			exit 1
			;;
		esac
		;;

	help | --help | -h)
		shift
		case "$1" in
		setup) usage__setup ;;
		new) usage__new ;;
		add) usage__add ;;
		"") usage ;;
		*)
			echo "Error: Unknown command '$1'" >&2
			exit 1
			;;
		esac
		;;
	--version) echo "$CMD_NAME v$CMD_VERSION" ;;
	"") usage ;;
	*)
		echo "Error: Unknown command or flag '$1'" >&2
		echo "Try $CMD_NAME --help to see instructions" >&2
		exit 1
		;;
	esac
}

main "$@"
